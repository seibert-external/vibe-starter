{
  "name": "tts",
  "private": true,
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.15.1+sha512.34e538c329b5553014ca8e8f4535997f96180a1d0f614339357449935350d924e22f8614682191264ec33d1462ac21561aff97f6bb18065351c162c7e8f6de67",
  "scripts": {
    "dev": "NODE_ENV=development dotenvx run -- turbo dev",
    "build": "dotenvx run -- turbo build",
    "lint": "dotenvx run -- turbo lint",
    "lint:fix": "dotenvx run -- turbo lint:fix",
    "format": "turbo format",
    "format:fix": "turbo format:fix",
    "fix": "dotenvx run -- turbo fix",
    "check": "dotenvx run -- turbo check",
    "test": "dotenvx run -- turbo test",
    "test:watch": "dotenvx run -- turbo test:watch",
    "test:coverage": "dotenvx run -- turbo test:coverage",
    "db:migrate:dev": "dotenvx run -- pnpm --filter @repo/database migrate:dev",
    "db:migrate:deploy": "dotenvx run -- pnpm --filter @repo/database migrate:deploy",
    "db:studio": "dotenvx run -- pnpm --filter @repo/database studio"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "next": "^16.1.6",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3"
  }
}
